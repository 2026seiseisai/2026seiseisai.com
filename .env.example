# ==========================================
# 文化祭ホームページ 環境変数設定ファイル
# ==========================================
# このファイルをコピーして .env.local を作成してください
# .env.local は .gitignore に含まれているため Git にはコミットされません

# ----- サイト設定 -----
NEXT_PUBLIC_SITE_URL=https://your-site-url.com
NEXT_PUBLIC_SITE_NAME=文化祭 2025

# ----- 開催情報 -----
NEXT_PUBLIC_EVENT_DATE=2025-XX-XX
NEXT_PUBLIC_VENUE=〇〇高校

# ----- SNS リンク（公開設定） -----
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your_account
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_account
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@your_channel

# ----- Google Analytics（任意） -----
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----- お問い合わせフォーム（任意） -----
# CONTACT_FORM_EMAIL=info@example.com
